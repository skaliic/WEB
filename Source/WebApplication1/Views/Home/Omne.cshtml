}

<header class="nadpis">
    <h1>O MNĚ</h1>
</header>
<nav>
    <a asp-controller="Home" asp-action="Index">Domů</a>
    <a asp-controller="Home" asp-action="Omne" class="active">O mně</a>
    <a asp-controller="Home" asp-action="MojeTrasy">Moje Trasy</a>
    <a asp-controller="Home" asp-action="Reference">Reference</a>
